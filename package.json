{
  "name": "claude-hook-logger",
  "version": "1.0.0",
  "description": "Event logging system + web dashboard for Claude Code hooks",
  "type": "module",
  "main": "dist/electron/main.cjs",
  "scripts": {
    "dev": "vite --config web/vite.config.ts",
    "dev:server": "tsx viewer/start.ts",
    "build": "tsc -p tsconfig.json && vite build --config web/vite.config.ts && cp viewer/index.html dist/viewer/",
    "build:check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p web/tsconfig.json",
    "test": "node --import tsx/esm --experimental-test-module-mocks --test 'test/**/*.test.ts'",
    "test:coverage": "node --import tsx/esm --experimental-test-module-mocks --test --experimental-test-coverage --test-coverage-exclude='test/**' --test-coverage-exclude='lib/settings-merge-cli.ts' --test-coverage-exclude='viewer/start.ts' 'test/**/*.test.ts'",
    "electron:build:ts": "tsc -p electron/tsconfig.json",
    "electron:dev": "ELECTRON_DEV=1 electron dist/electron/main.cjs",
    "electron:start": "electron dist/electron/main.cjs",
    "electron:build": "pnpm run build && pnpm run electron:build:ts && pnpm exec electron-builder --mac"
  },
  "keywords": [
    "claude",
    "claude-code",
    "hooks",
    "logging",
    "dashboard"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.45",
    "@tanstack/react-virtual": "^3.13.23",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "zod": "^4.3.6"
  },
  "build": {
    "appId": "com.claude-hook-logger.app",
    "productName": "Claude Hook Logger",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg"]
    },
    "files": [
      "dist/**/*",
      "!dist/web/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/web",
        "to": "web"
      },
      {
        "from": "viewer/index.html",
        "to": "viewer/index.html"
      }
    ],
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  }
}
